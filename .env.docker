# Coze API 配置
# 请访问 https://www.coze.cn/ 或 https://www.coze.com/ 获取这些凭据

# Coze API 密钥（必填）
# 格式：pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COZE_API_KEY=pat_your_api_key_here

# Coze API 基础 URL（必填）
# 国内版：https://api.coze.cn
# 国际版：https://api.coze.com
COZE_BASE_URL=https://api.coze.cn

# Coze Bot ID（必填）
# 格式：纯数字，如 7380123456789012345
COZE_BOT_ID=your_bot_id_here
