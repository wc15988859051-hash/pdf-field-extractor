# ==============================================
# PDF 字段提取应用 - 环境变量示例
# 复制此文件为 .env 并填入实际值
# ==============================================

# Node.js 环境
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# Coze API 配置（如果需要）
# COZE_API_KEY=your_coze_api_key_here
# COZE_API_BASE=https://api.coze.cn

# 其他配置
# MAX_FILE_SIZE=10485760  # 最大文件大小（字节），默认 10MB
# ALLOWED_FILE_TYPES=.pdf  # 允许的文件类型
